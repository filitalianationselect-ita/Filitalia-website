/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), browsing-topics=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://formsubmit.co; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://cdn-icons-png.flaticon.com https://*.supabase.co; connect-src 'self' https://script.google.com https://script.googleusercontent.com https://*.supabase.co wss://*.supabase.co https://api.mymemory.translated.net; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; media-src 'self' blob:; upgrade-insecure-requests

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/*.js
  Cache-Control: public, max-age=3600, must-revalidate

/*.css
  Cache-Control: public, max-age=3600, must-revalidate

/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/generated/*
  Cache-Control: public, max-age=0, must-revalidate

/account.html
  Cache-Control: no-store

/login.html
  Cache-Control: no-store

/reset-password.html
  Cache-Control: no-store
